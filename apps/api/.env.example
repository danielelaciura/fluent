# Server
PORT=3000
HOST=0.0.0.0

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/meetfluent

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Auth (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production

# AI Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage (Cloudflare R2 / S3-compatible)
S3_ENDPOINT=
S3_BUCKET=meetfluent-audio
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
